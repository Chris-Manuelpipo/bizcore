<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

  <!--
    Migration 013 — Ajout du tenant_id sur toutes les entités métier
    Dépend de : 012-create-tenants.xml (la table tenants doit exister)
    Couche 3 BCaaS : isolation multitenant (analogie VLAN)

    IMPORTANT : tenant_id est nullable ici pour ne pas bloquer les données
    existantes en base. Une fois les données migrées vers un tenant,
    passe-le NOT NULL dans une migration 013b si nécessaire.
  -->

  <!-- ════════════════════════════════════════════════════════
       businesses — le métier appartient à un tenant
       ════════════════════════════════════════════════════════ -->
  <changeSet id="013-businesses-tenant" author="bizcore">
    <preConditions onFail="MARK_RAN">
      <not><columnExists tableName="businesses" columnName="tenant_id"/></not>
    </preConditions>
    <addColumn tableName="businesses">
      <column name="tenant_id" type="uuid"/>
    </addColumn>
    <addForeignKeyConstraint
      constraintName="fk_businesses_tenant"
      baseTableName="businesses"
      baseColumnNames="tenant_id"
      referencedTableName="tenants"
      referencedColumnNames="id"/>
    <createIndex tableName="businesses" indexName="idx_businesses_tenant_id">
      <column name="tenant_id"/>
    </createIndex>
  </changeSet>

