# =============================================================================
# BizCore Backend - Docker Ignore File
# Exclude unnecessary files from Docker build context
# =============================================================================

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.gitkeep

# -----------------------------------------------------------------------------
# IDE and Editor files
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md
!README.md
docs/
DOCUMENTATION.md

# -----------------------------------------------------------------------------
# Maven wrapper JARs (not needed in Docker build)
# -----------------------------------------------------------------------------
.mvn/wrapper/*.jar

# -----------------------------------------------------------------------------
# Test files (not needed for production build)
# -----------------------------------------------------------------------------
src/test/
*.test.js
*.test.ts
__tests__/

# -----------------------------------------------------------------------------
# Configuration and sensitive files
# -----------------------------------------------------------------------------
*.env
*.env.local
*.env.*.local
application-local.properties
application-local.yml

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
tmp/
temp/

# -----------------------------------------------------------------------------
# Node.js (if any frontend code)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Docker files (don't recurse into docker context)
# -----------------------------------------------------------------------------
docker-compose*.yml
Dockerfile*
.dockerignore
